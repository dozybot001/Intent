{
  "schema_version": "0.1",
  "manifest_version": "2026-03-17",
  "integrations": [
    {
      "id": "codex",
      "display_name": "Codex",
      "description": "Install the Intent skill into the global Codex skills directory.",
      "install_mode": "skill_dir",
      "source_dir": "codex",
      "detection": {
        "env_any": [
          "CODEX_HOME"
        ],
        "paths_any": [
          "~/.codex"
        ]
      },
      "target": {
        "home_env": "CODEX_HOME",
        "home_default": "~/.codex",
        "relative_dir": "skills/intent-cli",
        "entrypoint": "SKILL.md"
      }
    },
    {
      "id": "claude",
      "display_name": "Claude Code",
      "description": "Install the Intent skill into the global Claude skills directory.",
      "install_mode": "skill_dir",
      "source_dir": "claude",
      "detection": {
        "env_any": [
          "CLAUDE_HOME"
        ],
        "paths_any": [
          "~/.claude"
        ]
      },
      "target": {
        "home_env": "CLAUDE_HOME",
        "home_default": "~/.claude",
        "relative_dir": "skills/intent-cli",
        "entrypoint": "SKILL.md"
      }
    },
    {
      "id": "cursor",
      "display_name": "Cursor",
      "description": "Stage a Cursor helper rule and explain the remaining manual step.",
      "install_mode": "manual_helper",
      "source_dir": "cursor",
      "detection": {
        "env_any": [
          "CURSOR_HOME"
        ],
        "paths_any": [
          "~/.cursor"
        ]
      },
      "helper": {
        "entrypoint": "intent.mdc"
      }
    }
  ]
}
